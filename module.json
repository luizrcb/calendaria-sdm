{
  "id": "calendaria-sdm",
  "title": "Calendaria: SDM",
  "description": "The Rainbowlands calendar for UVG (Ultraviolet Grasslands) and OGA (Our Golden Age)",
  "version": "#{VERSION}#",
  "library": "false",
  "compatibility": {
    "minimum": 13,
    "verified": 13
  },
  "authors": [
    {
      "name": "Luber",
      "discord": "luizbertoni",
      "email": "luizrcb@gmail.com",
      "url": "https://foundryvtt.com/community/luizbertoni"
    }
  ],
  "relationships": {
    "requires": [
      {
        "id": "calendaria",
        "type": "module",
        "compatibility": {
          "minimum": "1.0.4"
        }
      }
    ]
  },
  "esmodules": [
    "scripts/module.js"
  ],
  "styles": [
    "styles/module.css"
  ],
  "languages": [
